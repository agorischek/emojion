{
  "name": "emj",
  "version": "0.0.8",
  "description": "Emoji Object Notation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agorischek/emojion.git"
  },
  "author": {
    "name": "Alex Gorischek",
    "email": "alex.gorischek@gmail.com",
    "url": "https://github.com/agorischek/emojion#readme"
  },
  "keywords": [
    "object notation"
  ],
  "files": [
    "lib"
  ],
  "main": "lib/src/index.js",
  "scripts": {
    "clean": "rimraf lib && rimraf coverage",
    "format": "prettier --write \"{src,test}/**/*.ts\" && prettier --write README.md",
    "lint": "eslint src/**/*.ts",
    "prebuild": "npm run clean && npm run format && npm run lint && echo Using TypeScript && tsc --version",
    "build": "npm run build:grammar && npm run build:lib && npm run build:bundle",
    "build:grammar": "mkdir -p gen && nearleyc src/grammar.ne -o gen/grammar.ts && replace-in-file \"Lexer: lexer,\" \"// @ts-ignore\nLexer: lexer,\" gen/grammar.ts",
    "build:bundle": "npm run rollup",
    "build:lib": "tsc --pretty",
    "start": "npm run build && npm run test",
    "test": "npm run build:grammar && vitest run",
    "coverage": "npm run build:grammar && vitest run --coverage",
    "update": "ncu -u && npm i && npm test",
    "rollup": "rollup --config rollup.config.mjs",
    "watch": "npm run build -- --watch",
    "watch:test": "vitest"
  },
  "dependencies": {
    "lodash": "^4.18.1",
    "moo": "^0.5.3",
    "nearley": "^2.20.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/lodash": "^4.17.24",
    "@types/moo": "^0.5.10",
    "@types/nearley": "^2.11.5",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "npm-check-updates": "^22.1.1",
    "prettier": "^3.8.3",
    "replace-in-file": "^8.4.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.3",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=10.0.0"
  }
}
